# =============================================================================
# AdSparkX Persona-Adaptive Customer Support — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Google Gemini API Key (REQUIRED)
# Get your free API key at: https://aistudio.google.com/app/apikey
# The free tier allows 60 requests per minute.
GEMINI_API_KEY=your_gemini_api_key_here

# ChromaDB persistence directory (optional)
# Defaults to ./chroma_db relative to project root.
# This directory is auto-created on first run and is gitignored.
CHROMA_DB_PATH=./chroma_db

# Logging level (optional, defaults to INFO)
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
